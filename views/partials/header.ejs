<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | <%= process.env.GYM_NAME || 'Gym Manager' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Rajdhani:wght@600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>

<div class="wrapper">
  <!-- Sidebar -->
  <nav class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <i class="bi bi-lightning-charge-fill brand-icon"></i>
      <span class="brand-name"><%= process.env.GYM_NAME || 'GymPro' %></span>
    </div>
    <div class="sidebar-menu">
      <div class="menu-label">MAIN</div>
      <a href="/dashboard" class="menu-item <%= title === 'Dashboard' ? 'active' : '' %>">
        <i class="bi bi-speedometer2"></i><span>Dashboard</span>
      </a>
      <a href="/members" class="menu-item <%= title === 'Members' ? 'active' : '' %>">
        <i class="bi bi-people-fill"></i><span>Members</span>
      </a>
      <a href="/enquiry" class="menu-item <%= title === 'Enquiries' ? 'active' : '' %>">
        <i class="bi bi-chat-dots-fill"></i><span>Enquiries</span>
      </a>
      <div class="menu-label">FINANCE</div>
      <a href="/billing" class="menu-item <%= title === 'Billing' ? 'active' : '' %>">
        <i class="bi bi-receipt-cutoff"></i><span>Billing</span>
      </a>
      <a href="/plans" class="menu-item <%= title === 'Plans' ? 'active' : '' %>">
        <i class="bi bi-card-list"></i><span>Plans</span>
      </a>
      <a href="/offers" class="menu-item <%= title === 'Offers & Discounts' ? 'active' : '' %>">
        <i class="bi bi-tag-fill"></i><span>Offers</span>
      </a>
      <div class="menu-label">TRACKING</div>
      <a href="/attendance" class="menu-item <%= title === 'Attendance' ? 'active' : '' %>">
        <i class="bi bi-fingerprint"></i><span>Attendance</span>
      </a>
      <a href="/reports" class="menu-item <%= title === 'Monthly Reports' ? 'active' : '' %>">
        <i class="bi bi-bar-chart-fill"></i><span>Reports</span>
      </a>
      <div class="menu-label">SYSTEM</div>
      <a href="/fingerprint/devices" class="menu-item <%= title === 'Fingerprint Management' ? 'active' : '' %>">
        <i class="bi bi-fingerprint"></i><span>Fingerprints</span>
      </a>
      <a href="/settings" class="menu-item <%= title === 'eSSL / Device Settings' ? 'active' : '' %>">
        <i class="bi bi-hdd-network-fill"></i><span>eSSL Settings</span>
      </a>
    </div>
    <div class="sidebar-footer">
      <a href="/auth/logout" class="menu-item logout-btn">
        <i class="bi bi-box-arrow-left"></i><span>Logout</span>
      </a>
    </div>
  </nav>

  <!-- Main Content -->
  <div class="main-content">
    <!-- Topbar -->
    <nav class="topbar">
      <button class="sidebar-toggle" onclick="toggleSidebar()">
        <i class="bi bi-list fs-4"></i>
      </button>
      <div class="topbar-title"><%= title %></div>
      <div class="topbar-right">
        <span class="d-none d-md-inline text-muted small me-3">
          <i class="bi bi-calendar3 me-1"></i><%= new Date().toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %>
        </span>
        <div class="admin-badge">
          <i class="bi bi-shield-check-fill me-1"></i>Admin
        </div>
      </div>
    </nav>

    <!-- Flash Messages -->
    <div class="px-4 pt-3">
      <% if (typeof messages !== 'undefined') { %>
        <% if (messages.success && messages.success.length) { %>
          <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-check-circle-fill"></i>
            <%= messages.success[0] %>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        <% if (messages.error && messages.error.length) { %>
          <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <%= messages.error[0] %>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
      <% } %>
    </div>

    <!-- Page Content starts here -->
    <div class="page-content">
