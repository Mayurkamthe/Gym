<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h5 class="fw-700 mb-1">Enquiry Management</h5>
    <p class="text-muted small mb-0">Track leads and follow-ups</p>
  </div>
  <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addModal">
    <i class="bi bi-plus-lg me-1"></i>New Enquiry
  </button>
</div>

<!-- Status Tabs -->
<div class="d-flex gap-2 mb-3 flex-wrap">
  <a href="/enquiry" class="badge-tab <%= !status ? 'active' : '' %>">All <span class="ms-1"><%= counts.all %></span></a>
  <a href="/enquiry?status=New" class="badge-tab <%= status === 'New' ? 'active' : '' %>">New <span class="ms-1"><%= counts.New %></span></a>
  <a href="/enquiry?status=Interested" class="badge-tab <%= status === 'Interested' ? 'active' : '' %>">Interested <span class="ms-1"><%= counts.Interested %></span></a>
  <a href="/enquiry?status=Joined" class="badge-tab <%= status === 'Joined' ? 'active' : '' %>">Joined <span class="ms-1"><%= counts.Joined %></span></a>
</div>

<!-- Search -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body py-2">
    <form class="d-flex gap-2" method="GET">
      <% if (status) { %><input type="hidden" name="status" value="<%= status %>"/><% } %>
      <input type="text" name="search" class="form-control" placeholder="Search name or phone..." value="<%= search || '' %>"/>
      <button class="btn btn-primary px-4" type="submit"><i class="bi bi-search"></i></button>
      <a href="/enquiry<%= status ? '?status=' + status : '' %>" class="btn btn-outline-secondary">Clear</a>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr><th>Name</th><th>Phone</th><th>Goal</th><th>Source</th><th>Follow-up</th><th>Status</th><th>Actions</th></tr>
        </thead>
        <tbody>
          <% if (!enquiries.length) { %>
            <tr><td colspan="7" class="text-center text-muted py-5"><i class="bi bi-inbox fs-1 d-block mb-2"></i>No enquiries found</td></tr>
          <% } %>
          <% enquiries.forEach(e => { %>
          <% const statusColors = {New:'primary',Interested:'warning',Joined:'success','Not Interested':'secondary','Follow-up':'info'}; %>
          <tr>
            <td><div class="fw-600"><%= e.name %></div><div class="text-muted small"><%= e.email || '' %></div></td>
            <td>
              <a href="tel:<%= e.phone %>" class="text-decoration-none"><i class="bi bi-telephone me-1 text-primary"></i><%= e.phone %></a><br/>
              <a href="https://wa.me/91<%= e.phone.replace(/\D/g,'') %>" target="_blank" class="text-success small"><i class="bi bi-whatsapp me-1"></i>Chat</a>
            </td>
            <td class="small"><%= e.goal || '—' %></td>
            <td><span class="badge bg-light text-dark"><%= e.source %></span></td>
            <td class="small <%= e.follow_up_date && new Date(e.follow_up_date) <= new Date() ? 'text-danger fw-600' : '' %>">
              <%= e.follow_up_date ? new Date(e.follow_up_date).toLocaleDateString('en-IN') : '—' %>
            </td>
            <td><span class="badge bg-<%= statusColors[e.status] || 'secondary' %>-subtle text-<%= statusColors[e.status] || 'secondary' %>"><%= e.status %></span></td>
            <td>
              <button class="btn btn-sm btn-outline-warning me-1" onclick="editEnquiry(<%= e.id %>)" title="Edit"><i class="bi bi-pencil"></i></button>
              <form action="/enquiry/<%= e.id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete?')">
                <button class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-700"><i class="bi bi-chat-dots me-2 text-primary"></i>New Enquiry</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/enquiry" method="POST">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-6"><label class="form-label fw-600">Name *</label><input type="text" name="name" class="form-control" required/></div>
            <div class="col-md-6"><label class="form-label fw-600">Phone *</label><input type="tel" name="phone" class="form-control" required/></div>
            <div class="col-md-6"><label class="form-label fw-600">Email</label><input type="email" name="email" class="form-control"/></div>
            <div class="col-md-6"><label class="form-label fw-600">Goal</label><input type="text" name="goal" class="form-control" placeholder="Weight loss, muscle gain..."/></div>
            <div class="col-md-4"><label class="form-label fw-600">Source</label>
              <select name="source" class="form-select">
                <% ['Walk-in','Instagram','Facebook','WhatsApp','Reference','Other'].forEach(s => { %><option><%= s %></option><% }) %>
              </select>
            </div>
            <div class="col-md-4"><label class="form-label fw-600">Status</label>
              <select name="status" class="form-select">
                <% ['New','Interested','Not Interested','Joined','Follow-up'].forEach(s => { %><option><%= s %></option><% }) %>
              </select>
            </div>
            <div class="col-md-4"><label class="form-label fw-600">Follow-up Date</label><input type="date" name="follow_up_date" class="form-control"/></div>
            <div class="col-12"><label class="form-label fw-600">Notes</label><textarea name="notes" class="form-control" rows="2"></textarea></div>
          </div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary">Save Enquiry</button></div>
      </form>
    </div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-700"><i class="bi bi-pencil me-2 text-warning"></i>Edit Enquiry</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="editForm" method="POST">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-6"><label class="form-label fw-600">Name *</label><input type="text" name="name" id="edit_name" class="form-control" required/></div>
            <div class="col-md-6"><label class="form-label fw-600">Phone *</label><input type="tel" name="phone" id="edit_phone" class="form-control" required/></div>
            <div class="col-md-6"><label class="form-label fw-600">Email</label><input type="email" name="email" id="edit_email" class="form-control"/></div>
            <div class="col-md-6"><label class="form-label fw-600">Goal</label><input type="text" name="goal" id="edit_goal" class="form-control"/></div>
            <div class="col-md-4"><label class="form-label fw-600">Source</label>
              <select name="source" id="edit_source" class="form-select">
                <% ['Walk-in','Instagram','Facebook','WhatsApp','Reference','Other'].forEach(s => { %><option value="<%= s %>"><%= s %></option><% }) %>
              </select>
            </div>
            <div class="col-md-4"><label class="form-label fw-600">Status</label>
              <select name="status" id="edit_status" class="form-select">
                <% ['New','Interested','Not Interested','Joined','Follow-up'].forEach(s => { %><option value="<%= s %>"><%= s %></option><% }) %>
              </select>
            </div>
            <div class="col-md-4"><label class="form-label fw-600">Follow-up Date</label><input type="date" name="follow_up_date" id="edit_followup" class="form-control"/></div>
            <div class="col-12"><label class="form-label fw-600">Notes</label><textarea name="notes" id="edit_notes" class="form-control" rows="2"></textarea></div>
          </div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-warning">Update</button></div>
      </form>
    </div>
  </div>
</div>

<script>
async function editEnquiry(id) {
  const res = await fetch(`/enquiry/${id}/json`);
  const e = await res.json();
  document.getElementById('edit_name').value = e.name || '';
  document.getElementById('edit_phone').value = e.phone || '';
  document.getElementById('edit_email').value = e.email || '';
  document.getElementById('edit_goal').value = e.goal || '';
  document.getElementById('edit_source').value = e.source || 'Walk-in';
  document.getElementById('edit_status').value = e.status || 'New';
  document.getElementById('edit_followup').value = e.follow_up_date || '';
  document.getElementById('edit_notes').value = e.notes || '';
  document.getElementById('editForm').action = `/enquiry/${id}/update`;
  new bootstrap.Modal(document.getElementById('editModal')).show();
}
</script>
<%- include('../partials/footer') %>
