<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h5 class="fw-700 mb-1">Offers & Discounts</h5>
    <p class="text-muted small mb-0">Create and manage promotional offers</p>
  </div>
  <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addOfferModal">
    <i class="bi bi-plus-lg me-1"></i>New Offer
  </button>
</div>

<div class="row g-3">
  <% offers.forEach(o => { %>
  <% const isActive = o.status === 'active' && o.valid_from <= today && o.valid_to >= today; %>
  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100 offer-card <%= isActive ? 'offer-active' : 'offer-inactive' %>">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-2">
          <h6 class="fw-700 mb-0"><%= o.name %></h6>
          <span class="badge <%= isActive ? 'bg-success' : 'bg-secondary' %>"><%= isActive ? 'Live' : 'Inactive' %></span>
        </div>
        <div class="offer-value-badge mb-3">
          <% if (o.type === 'flat') { %>
            <i class="bi bi-currency-rupee"></i><span><%= parseFloat(o.value).toLocaleString('en-IN') %> OFF</span>
          <% } else { %>
            <i class="bi bi-percent"></i><span><%= o.value %>% OFF</span>
          <% } %>
        </div>
        <div class="small text-muted mb-1"><i class="bi bi-calendar-range me-1"></i><%= new Date(o.valid_from).toLocaleDateString('en-IN') %> → <%= new Date(o.valid_to).toLocaleDateString('en-IN') %></div>
        <% if (o.description) { %><p class="text-muted small mb-3"><%= o.description %></p><% } %>
        <div class="d-flex gap-2 mt-3">
          <button class="btn btn-sm btn-outline-warning flex-grow-1" onclick="editOffer(<%= o.id %>)"><i class="bi bi-pencil me-1"></i>Edit</button>
          <form action="/offers/<%= o.id %>/delete" method="POST" onsubmit="return confirm('Delete offer?')">
            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
          </form>
        </div>
      </div>
    </div>
  </div>
  <% }) %>
  <% if (!offers.length) { %>
  <div class="col-12 text-center text-muted py-5">
    <i class="bi bi-tag fs-1 d-block mb-2"></i>No offers yet. Create your first discount!
  </div>
  <% } %>
</div>

<!-- Add Modal -->
<div class="modal fade" id="addOfferModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-700"><i class="bi bi-tag-fill me-2 text-primary"></i>New Offer</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/offers" method="POST">
        <div class="modal-body">
          <div class="mb-3"><label class="form-label fw-600">Offer Name *</label><input type="text" name="name" class="form-control" placeholder="e.g. New Year Special" required/></div>
          <div class="row g-2 mb-3">
            <div class="col-6"><label class="form-label fw-600">Type *</label>
              <select name="type" class="form-select" required>
                <option value="flat">Flat (₹ OFF)</option>
                <option value="percentage">Percentage (% OFF)</option>
              </select>
            </div>
            <div class="col-6"><label class="form-label fw-600">Value *</label><input type="number" name="value" class="form-control" step="0.01" required/></div>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-6"><label class="form-label fw-600">Valid From *</label><input type="date" name="valid_from" class="form-control" required/></div>
            <div class="col-6"><label class="form-label fw-600">Valid To *</label><input type="date" name="valid_to" class="form-control" required/></div>
          </div>
          <div class="mb-3"><label class="form-label fw-600">Status</label>
            <select name="status" class="form-select"><option value="active">Active</option><option value="inactive">Inactive</option></select>
          </div>
          <div class="mb-3"><label class="form-label fw-600">Description</label><textarea name="description" class="form-control" rows="2"></textarea></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-primary">Save Offer</button></div>
      </form>
    </div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editOfferModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-700"><i class="bi bi-pencil me-2 text-warning"></i>Edit Offer</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="editOfferForm" method="POST">
        <div class="modal-body">
          <div class="mb-3"><label class="form-label fw-600">Offer Name *</label><input type="text" name="name" id="eo_name" class="form-control" required/></div>
          <div class="row g-2 mb-3">
            <div class="col-6"><label class="form-label fw-600">Type</label>
              <select name="type" id="eo_type" class="form-select">
                <option value="flat">Flat (₹ OFF)</option>
                <option value="percentage">Percentage (% OFF)</option>
              </select>
            </div>
            <div class="col-6"><label class="form-label fw-600">Value</label><input type="number" name="value" id="eo_value" class="form-control" step="0.01"/></div>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-6"><label class="form-label fw-600">Valid From</label><input type="date" name="valid_from" id="eo_from" class="form-control"/></div>
            <div class="col-6"><label class="form-label fw-600">Valid To</label><input type="date" name="valid_to" id="eo_to" class="form-control"/></div>
          </div>
          <div class="mb-3"><label class="form-label fw-600">Status</label>
            <select name="status" id="eo_status" class="form-select"><option value="active">Active</option><option value="inactive">Inactive</option></select>
          </div>
          <div class="mb-3"><label class="form-label fw-600">Description</label><textarea name="description" id="eo_desc" class="form-control" rows="2"></textarea></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-warning">Update</button></div>
      </form>
    </div>
  </div>
</div>

<script>
async function editOffer(id) {
  const res = await fetch(`/offers/${id}/json`);
  const o = await res.json();
  document.getElementById('eo_name').value = o.name;
  document.getElementById('eo_type').value = o.type;
  document.getElementById('eo_value').value = o.value;
  document.getElementById('eo_from').value = o.valid_from;
  document.getElementById('eo_to').value = o.valid_to;
  document.getElementById('eo_status').value = o.status;
  document.getElementById('eo_desc').value = o.description || '';
  document.getElementById('editOfferForm').action = `/offers/${id}/update`;
  new bootstrap.Modal(document.getElementById('editOfferModal')).show();
}
</script>
<%- include('../partials/footer') %>
